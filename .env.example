# Trail Tails — environment variables
# Copy to .env.local and fill in values.

# --- Database (required for migrations / seed) ---
# Dashboard → Project Settings → Database → Database password
SUPABASE_DB_PASSWORD=your_database_password

# Optional overrides (defaults work for project wvriybvnsjfhlsnwkqrv)
# SUPABASE_DB_HOST=aws-0-us-west-1.pooler.supabase.com
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_USER=postgres.wvriybvnsjfhlsnwkqrv

# Built automatically by scripts/sync-env.sh from password + host (URL-encoded)
# DATABASE_URL=postgresql://...

# --- Supabase CLI (optional — only if not using DATABASE_URL / psql) ---
# Dashboard → Account → Access Tokens (NOT anon or service role key)
# Or run: npx supabase login  (stores token locally, no .env needed)
# SUPABASE_ACCESS_TOKEN=

# --- Next.js app (Phase 4+) ---
NEXT_PUBLIC_SUPABASE_URL=https://wvriybvnsjfhlsnwkqrv.supabase.co

# New-format publishable key (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy name — sync-env.sh copies from publishable if unset
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret — fetch via: npx supabase login && bash scripts/fetch-supabase-keys.sh
SUPABASE_SERVICE_ROLE_KEY=

# --- Twilio (Phase 8) ---
# Dashboard → Account → API keys & tokens
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio phone number in E.164, e.g. +15551234567
TWILIO_PHONE_NUMBER=
# Public URL Twilio posts to (required for signature validation in production)
# e.g. https://your-app.netlify.app/api/webhooks/twilio
TWILIO_WEBHOOK_URL=
# Pilot/testing: send all outbound customer SMS here instead (prefixes with customer/dog name)
# TWILIO_SMS_REDIRECT_TO=+16045551234

# --- Google Maps (geocoding + ETA) ---
# Cloud Console → APIs & Services → Geocoding API + Routes API
GOOGLE_MAPS_API_KEY=

# --- Scheduled jobs (Phase A) ---
# Random secret for GET /api/cron/night-before (Authorization: Bearer …)
CRON_SECRET=
